<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:padding="18dp">

        <!-- Scheme Name + Tag -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_scheme_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="PM-JAY"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tv_scheme_tag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Central"
                android:textSize="11sp"
                android:textColor="@color/green_primary"
                android:background="@drawable/bg_chip_green"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_scheme_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Free treatment up to ₹5 lakh per year"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="12dp"/>

        <!-- Coverage + Documents row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_green_light_card"
                android:padding="10dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COVERAGE"
                    android:textSize="9sp"
                    android:textColor="@color/text_hint"
                    android:letterSpacing="0.08"/>

                <TextView
                    android:id="@+id/tv_coverage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹5,00,000"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/green_dark"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_green_light_card"
                android:padding="10dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DOCUMENTS"
                    android:textSize="9sp"
                    android:textColor="@color/text_hint"
                    android:letterSpacing="0.08"/>

                <TextView
                    android:id="@+id/tv_doc_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6 documents needed"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/green_dark"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Authority -->
        <TextView
            android:id="@+id/tv_authority"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="National Health Authority"
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:layout_marginTop="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap to see Document Checklist →"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/green_primary"
            android:layout_marginTop="4dp"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
