<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:padding="18dp">

        <!-- Name + Type Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tv_hospital_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Victoria Hospital"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tv_hospital_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏛 Govt."
                android:textSize="11sp"
                android:textColor="@color/green_primary"
                android:background="@drawable/bg_chip_green"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_district"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍 Bengaluru"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tv_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fort Road, Bengaluru – 560002"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tv_phone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📞 080-26701150"
            android:textSize="13sp"
            android:textColor="@color/green_dark"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- Specialties -->
        <TextView
            android:id="@+id/tv_specialties"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="General Surgery • Orthopaedics • Gynaecology"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_schemes_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4 schemes accepted"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/green_primary"
            android:background="@drawable/bg_chip_green"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
